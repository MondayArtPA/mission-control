# Mission Control sample environment variables
# Copy this file to .env.local and fill in the secrets below.

# Provider API keys used by /api/expenses/sync
ANTHROPIC_API_KEY="sk-ant-..."
OPENROUTER_API_KEY="or_..."
OPENAI_API_KEY="sk-openai-..."

# Optional override for USD→THB conversion (defaults to 33 when unset)
# EXPENSES_USD_TO_THB=33
